+static s32 Dsce_AudioSeqChannelIsValid(SequenceChannel* channel) {
+    uintptr_t address = (uintptr_t)channel;
+    uintptr_t poolStart = (uintptr_t)gAudioCtx.miscPool.startAddr;
+    uintptr_t poolEnd = (uintptr_t)gAudioCtx.miscPool.curAddr;
+
+    if (channel == &gAudioCtx.sequenceChannelNone) {
+        return true;
+    }
+    return (address >= poolStart) && ((address + sizeof(SequenceChannel)) <= poolEnd) &&
+           ((address & 0xF) == 0);
+}
+
+static s32 Dsce_AudioSeqLayerIsValid(SequenceLayer* layer) {
+    uintptr_t address;
+    uintptr_t poolStart;
+    uintptr_t poolEnd;
+
+    if (layer == NULL) {
+        return true;
+    }
+    address = (uintptr_t)layer;
+    poolStart = (uintptr_t)&gAudioCtx.sequenceLayers[0];
+    poolEnd = (uintptr_t)&gAudioCtx.sequenceLayers[ARRAY_COUNT(gAudioCtx.sequenceLayers)];
+    return (address >= poolStart) && (address < poolEnd) &&
+           (((address - poolStart) % sizeof(SequenceLayer)) == 0);
+}
+#endif
