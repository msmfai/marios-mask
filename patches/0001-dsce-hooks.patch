@@ -2565,6 +2565,23 @@ void AudioOcarina_PlayControllerInput(u8 isOcarinaSfxSuppressedWhenCancelled) {
 
         // Processes new and valid notes
         if ((sCurOcarinaPitch != OCARINA_PITCH_NONE) && (sPrevOcarinaPitch != sCurOcarinaPitch)) {
+            /* [DSCE] Mario SINGS the ocarina (inherited from the PC, monophonic): each note plays
+             * his voice clip PITCHED to the note (freqScale = 2^((semitone-base)/12), base A4=9 so
+             * one real note is the genuine unpitched sample) instead of the ocarina tone. The clip
+             * is Punch Hoo: the longest upbeat punch donor, on a generated fixed-pitch voice channel.
+             * Song recognition is untouched -- it runs off sCurOcarinaPitch, not the audio. */
+            extern int gDsceSpikeAlive;
+            extern f32 Dsce_SingRatio(s32 semitone);
+            extern f32 gDsceSingFreq;
+            extern f32 gDsceSingVolume;
+            extern u32 gDsceSingNoteCount;
+            extern u16 gDsceSingSfxId;
+            if (gDsceSpikeAlive && (gSaveContext.save.playerForm == PLAYER_FORM_MARIO)) {
+                gDsceSingNoteCount++;
+                gDsceSingFreq = Dsce_SingRatio(sCurOcarinaPitch);
+                AudioSfx_PlaySfx(gDsceSingSfxId, &gSfxDefaultPos, 4, &gDsceSingFreq, &gDsceSingVolume,
+                                 &gSfxDefaultReverb);
+            } else {
             // Sets ocarina instrument Id to io port 7, which is used
             // as an index in seq 0 to get the true instrument Id
             AUDIOCMD_CHANNEL_SET_IO(SEQ_PLAYER_SFX, SFX_CHANNEL_OCARINA, 7, sOcarinaInstrumentId - 1);
@@ -2572,6 +2589,7 @@ void AudioOcarina_PlayControllerInput(u8 isOcarinaSfxSuppressedWhenCancelled) {
             AUDIOCMD_CHANNEL_SET_IO(SEQ_PLAYER_SFX, SFX_CHANNEL_OCARINA, 5, sCurOcarinaPitch);
             AudioSfx_PlaySfx(NA_SE_OC_OCARINA, &gSfxDefaultPos, 4, &sCurOcarinaBendFreq, &sDefaultOcarinaVolume,
                              &gSfxDefaultReverb);
+            }
         } else if ((sPrevOcarinaPitch != OCARINA_PITCH_NONE) && (sCurOcarinaPitch == OCARINA_PITCH_NONE) &&
                    !isOcarinaSfxSuppressedWhenCancelled) {
             // Stops ocarina sound when transitioning from playing to not playing a note
@@ -2659,6 +2677,16 @@ void AudioOcarina_SetInstrument(u8 ocarinaInstrumentId) {
             AudioOcarina_ReadControllerInput();
             sOcarinaInputButtonStart = sOcarinaInputButtonCur;
             // lowers volume of all sfx channels except system & ocarina banks
             Audio_SetSfxVolumeExceptSystemAndOcarinaBanks(0x40);
+            /* [DSCE] The PC singing mixer bypasses MM's ocarina duck. Our N64
+             * notes live in BANK_VOICE, so restore its two sequence channels or
+             * SingVolume 0.6 is silently halved to about 0.30. */
+            {
+                extern int gDsceSpikeAlive;
+                if (gDsceSpikeAlive && (gSaveContext.save.playerForm == PLAYER_FORM_MARIO)) {
+                    SEQCMD_SET_CHANNEL_VOLUME(SEQ_PLAYER_SFX, SFX_CHANNEL_VOICE0, 0, 0x7F);
+                    SEQCMD_SET_CHANNEL_VOLUME(SEQ_PLAYER_SFX, SFX_CHANNEL_VOICE1, 0, 0x7F);
